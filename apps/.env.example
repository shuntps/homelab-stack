# Vaultwarden
VAULTWARDEN_SUBDOMAIN=vault
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_INVITATIONS_ALLOWED=false
# Optional: set an Argon2 PHC admin token to enable /admin; leave blank to disable.
VAULTWARDEN_ADMIN_TOKEN=

# Pi-hole
PIHOLE_SUBDOMAIN=pihole
PIHOLE_DNS_BIND_IP=192.168.1.100
PIHOLE_WEB_PORT=80o
PIHOLE_DNS_UPSTREAMS=doh-proxy#5053
PIHOLE_DNS_LISTENING_MODE=ALL
PIHOLE_LOCAL_DOMAIN=lan
PIHOLE_DNS_DOMAIN_NEEDED=true
PIHOLE_DNS_BOGUS_PRIV=true
PIHOLE_QUERY_LOGGING=true
PIHOLE_CACHE_SIZE=10000
PIHOLE_CACHE_OPTIMIZER=3600
PIHOLE_BLOCKING_MODE=NULL
PIHOLE_RATE_LIMIT_COUNT=1000
PIHOLE_RATE_LIMIT_INTERVAL=60
PIHOLE_MAX_DB_DAYS=91
PIHOLE_WEBPASSWORD=replace_with_strong_pihole_password
