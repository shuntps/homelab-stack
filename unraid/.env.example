# Homelab
DOMAIN=example.com
TZ=America/Toronto
CONFIG_PATH=/mnt/cache/appdata
UID=1000
GID=100

# Cloudflare DDNS
CLOUDFLARE_DDNS_API_TOKEN=replace_with_cloudflare_dns_api_token
CLOUDFLARE_DDNS_DOMAINS=ddns.example.com
CLOUDFLARE_DDNS_UPDATE_CRON=@every 5m
CLOUDFLARE_DDNS_RECORD_COMMENT=managed-by-homelab-ddns

# Traefik
TRAEFIK_EXTERNAL_PORTAINER_URL=http://192.168.1.100:9000
TRAEFIK_EXTERNAL_UNRAID_URL=http://192.168.1.100:80
TRAEFIK_EXTERNAL_NAS_URL=http://192.168.1.101:80

# Redis / Valkey
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_strong_redis_password
REDIS_MAXMEMORY=128mb
REDIS_MAXMEMORY_POLICY=volatile-ttl

# Authelia
AUTHELIA_RESET_PASSWORD_JWT_SECRET=replace_with_random_reset_jwt_secret
AUTHELIA_SESSION_SECRET=replace_with_random_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=replace_with_random_storage_encryption_key
